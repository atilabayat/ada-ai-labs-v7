# ===========================================================================
# ADA AI Labs — Production Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control — it contains secrets.
#
# Required vars must be set for the app to function.
# Optional vars unlock additional features or override defaults.
# ===========================================================================


# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
# Var      : DATABASE_URL
# Purpose  : Prisma ORM connection string. Drives all structured data —
#            apps, wikis, builds, skills, knowledge graph, nav, and badges.
# Required : Yes
# SQLite   : file:./prisma/dev.db        (zero-config, local/Docker)
# Postgres : postgresql://user:pass@host:5432/ada_ai_labs?sslmode=require
#            → also set provider = "postgresql" in prisma/schema.prisma
#            → then run: npm run db:setup
DATABASE_URL=file:./prisma/dev.db


# ---------------------------------------------------------------------------
# ANTHROPIC API  —  LLM synthesis
# ---------------------------------------------------------------------------
# Var      : ANTHROPIC_API_KEY
# Purpose  : Authenticates requests to the Anthropic API. Used by the
#            builder's LLM synthesis step (the final "Synthesis" section
#            streamed after all skills run). If unset, a deterministic stub
#            runs instead — the pipeline is fully demoable without a key.
# Required : Yes (for live synthesis; stub runs without it)
# Get key  : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Var      : ANTHROPIC_MODEL
# Purpose  : Claude model used for build synthesis.
#            Override to switch between Opus / Sonnet / Haiku.
# Required : Yes
# Default  : claude-opus-4-6
ANTHROPIC_MODEL=claude-opus-4-6


# ---------------------------------------------------------------------------
# FIREWORKS AI  —  /llm-council true multi-model deliberation
# ---------------------------------------------------------------------------
# Var      : FIREWORKS_API_KEY
# Purpose  : Powers the /llm-council knowledge skill. When set, the council
#            queries several DIFFERENT open-weight models in parallel
#            (independent perspectives), then a chairman reconciles them.
#            Without it, /llm-council falls back to a single Anthropic model
#            role-playing the council, then to an offline composed read — so
#            the skill never breaks a chain.
# Required : No (optional upgrade; single-model fallback runs without it)
# Get key  : https://fireworks.ai → API Keys
# FIREWORKS_API_KEY=fw_xxxxxxxxxxxx

# Var      : FIREWORKS_MODELS
# Purpose  : Optional override of the council panel — comma-separated Fireworks
#            model ids. Unresponsive models are skipped gracefully.
# Required : No
# Default  : deepseek-v4-pro, kimi-k2p6, glm-5p1   (verified available on Fireworks)
# FIREWORKS_MODELS=accounts/fireworks/models/deepseek-v4-pro,accounts/fireworks/models/kimi-k2p6,accounts/fireworks/models/glm-5p1


# ---------------------------------------------------------------------------
# VOYAGE AI  —  Vector embeddings
# ---------------------------------------------------------------------------
# Var      : VOYAGE_API_KEY
# Purpose  : Authenticates requests to Voyage AI for voyage-3 embeddings
#            (1024-dim vectors). Used by:
#              • embedBuildOutput()   — indexes completed builds in Qdrant
#              • publishBuildAsWiki() — indexes new wikis in Qdrant
#              • searchKnowledge()    — embeds search queries at runtime
#            If unset, embedText() returns a zero-vector stub so the app
#            runs without errors — semantic search just returns no results.
# Required : Yes (for real semantic search; zero-vector stub used without it)
# Get key  : https://www.voyageai.com
VOYAGE_API_KEY=pa-xxxxxxxxxxxx


# ---------------------------------------------------------------------------
# QDRANT  —  Vector database
# ---------------------------------------------------------------------------
# Var      : QDRANT_URL
# Purpose  : Base URL of the Qdrant vector DB instance. Used by all
#            embedding read/write operations (upsert, search, health check).
#            In Docker Compose the next service references qdrant by its
#            service name: http://qdrant:6333
# Required : Yes
# Local    : http://localhost:6333
#            → docker run -p 6333:6333 qdrant/qdrant
# Docker   : http://qdrant:6333   (internal service name in compose)
# Cloud    : https://your-cluster.qdrant.io:6333
QDRANT_URL=http://localhost:6333

# Var      : QDRANT_API_KEY
# Purpose  : API key for authenticated Qdrant Cloud deployments.
#            Not required for self-hosted / local Qdrant instances.
# Required : Only for Qdrant Cloud
# QDRANT_API_KEY=your-qdrant-cloud-api-key


# ---------------------------------------------------------------------------
# NEXT.JS / DEPLOYMENT
# ---------------------------------------------------------------------------
# Var      : NODE_ENV
# Purpose  : Sets production mode in Next.js and all server-side guards.
#            Disables dev overlays, enables output caching and optimizations.
# Required : Yes (automatically set by Vercel, Railway, Render, etc.)
NODE_ENV=production

# Var      : VERCEL_URL
# Purpose  : Public base URL used for absolute links, OG metadata, and
#            canonical URLs. Set to your custom domain or Vercel preview URL.
# Required : Only when deploying to Vercel or a custom domain
# VERCEL_URL=https://your-domain.com


# ---------------------------------------------------------------------------
# MARKET DATA — Polygon.io
# ---------------------------------------------------------------------------
# Var      : POLYGON_API_KEY
# Purpose  : Powers all quant skill executors with live market data:
#              • /tsla-putwall   — live spot price + options chain (OI, walls)
#              • /callwall-monitor — live MAG-7 spot prices
#              • /market-data    — live index ETFs + MAG-7 snapshot
#              • /vix-regime     — live VIX proxies (VIXY, VXX)
#              • /dealer-flow    — top options by volume
#              • /ipa-compendium — live spot for detected ticker
#              • /morning-brief  — live MAG-7 prices
#            When unset, all executors fall back to hardcoded stub data
#            and output clearly notes "Data: stub".
# Required : No — stubs run without it; set for live trading research
# Tiers    : Free (5 req/min, stocks only) covers spot prices
#            Starter ($29/mo) adds options chain (OI, walls, flow)
# Get key  : https://polygon.io → Dashboard → API Keys
POLYGON_API_KEY=your-polygon-api-key

# ---------------------------------------------------------------------------
# WEB SEARCH — Tavily Search
# ---------------------------------------------------------------------------
# Var      : TAVILY_API_KEY
# Purpose  : Powers all research skill executors with live internet data:
#              • /web-search         — top web results + AI answer
#              • /deep-research      — 3-angle advanced search, full content
#              • /news-monitor       — breaking news (last 3d) + analyst coverage (2w)
#              • /literature-review  — academic + general research sources
#            When unset, those skills show a clear setup message.
#            /academic-search (arXiv) and /sec-filings (EDGAR) work without any key.
# Required : No — stubs run without it; set for live research
# Tiers    : Free (1k searches/mo) · Starter ($40/mo) for more volume
# Get key  : https://app.tavily.com → API Keys
TAVILY_API_KEY=tvly-your-key-here

# ---------------------------------------------------------------------------
# OPTIONAL / DEBUGGING
# ---------------------------------------------------------------------------
# Var      : DEBUG
# Purpose  : Enables verbose server-side logging across the build pipeline,
#            skill executors, and embedding operations.
# Required : No — omit in production unless actively debugging
# DEBUG=true
