# SQLite (default — zero-config, runs offline)
DATABASE_URL="file:./dev.db"

# Postgres (matches the ADGA stack). To use:
#   1. set provider = "postgresql" in prisma/schema.prisma
#   2. uncomment + edit the line below
#   3. run `npm run db:setup`
# DATABASE_URL="postgresql://user:password@localhost:5432/ada_ai_labs?schema=public"

# ---------------------------------------------------------------------------
# Builder synthesis — env-gated LLM
# ---------------------------------------------------------------------------
# If ANTHROPIC_API_KEY is set, the orchestrator streams from the real Anthropic
# API at the end of each build (the "synthesis" step). If unset, a
# deterministic stub runs instead so the pipeline is demoable without a key.
# ANTHROPIC_API_KEY="sk-ant-api03-..."
# ANTHROPIC_MODEL="claude-opus-4-6"

# ---------------------------------------------------------------------------
# Market data — Yahoo Finance (spot prices) + Tradier sandbox (options chains)
# ---------------------------------------------------------------------------
# Yahoo Finance provides spot prices for all quant skills — no key required.
# For live options chains (/tsla-putwall, /gamma-exposure, /dealer-flow):
#   1. Create a free account at https://tradier.com/create-account
#   2. Dashboard → API Access → Generate Token (Sandbox environment)
#   3. Paste the token below
# Without TRADIER_TOKEN, options skills fall back to stub data; spot skills work fine.
# TRADIER_TOKEN="your_sandbox_token_here"

# ---------------------------------------------------------------------------
# /llm-council — true multi-model deliberation (Fireworks AI)
# ---------------------------------------------------------------------------
# If FIREWORKS_API_KEY is set, /llm-council queries several DIFFERENT open-weight
# models in parallel (independent perspectives), then a chairman reconciles them.
# Without it, the skill falls back to a single Anthropic model role-playing the
# council. Get a key at https://fireworks.ai
# FIREWORKS_API_KEY="fw_..."
# Optional — override the panel (comma-separated Fireworks model ids).
# Default panel (verified available): deepseek-v4-pro, kimi-k2p6, glm-5p1
# FIREWORKS_MODELS="accounts/fireworks/models/deepseek-v4-pro,accounts/fireworks/models/kimi-k2p6,accounts/fireworks/models/glm-5p1"

# ---------------------------------------------------------------------------
# Embeddings — Voyage AI (voyage-3, 1024-dim vectors → Qdrant)
# ---------------------------------------------------------------------------
# If VOYAGE_API_KEY is set, embedText() calls voyage-3 for real vectors.
# If unset, a zero-vector stub is used so the pipeline runs without a key.
# Get a key at https://www.voyageai.com
# VOYAGE_API_KEY="pa-..."
# QDRANT_URL="http://localhost:6333"

# ---------------------------------------------------------------------------
# Web research — multi-source stack
# ---------------------------------------------------------------------------

# Tavily Search (free tier: 1,000 searches/month) — AI answer synthesis layer
# Powers: /web-search (answer overlay), /deep-research (context angle), /news-monitor, /literature-review
# Get key: https://app.tavily.com → API Keys (free signup)
# TAVILY_API_KEY="tvly-..."

# Brave Search (free tier: 2,000 queries/month) — primary web index (independent, not Bing/Google)
# Powers: /web-search (primary), /deep-research (all angles), /news-monitor (headlines)
# Get key: https://api.search.brave.com → Data for AI plan → free signup
# BRAVE_API_KEY="BSA..."

# Exa (free tier: 1,000 searches/month) — neural/semantic search layer
# Powers: /web-search (semantic pass), /deep-research (angle 1 semantic)
# Get key: https://exa.ai → Dashboard → API Keys (free signup)
# EXA_API_KEY="..."

# Semantic Scholar (optional — raises rate limit from 100 req/5min to 1 req/sec)
# Powers: /academic-search, /literature-review (always runs free without this key)
# Get key: https://www.semanticscholar.org/product/api → free registration
# SEMANTIC_SCHOLAR_API_KEY="..."

# ---------------------------------------------------------------------------
# Academic full-text — CORE Open Access (Tier 1)
# ---------------------------------------------------------------------------
# CORE (optional — raises from anonymous tier to 10k req/month)
# Powers: /academic-search, /literature-review (gracefully degrades to anon tier)
# Get key: https://core.ac.uk/services/api → free registration
# CORE_API_KEY="..."

# ---------------------------------------------------------------------------
# Economic data — FRED (Tier 3)
# ---------------------------------------------------------------------------
# FRED / Federal Reserve Economic Data (required for /social-science FRED section)
# Get key: https://fred.stlouisfed.org/docs/api/api_key.html → free registration
# FRED_API_KEY="..."

# ---------------------------------------------------------------------------
# News intelligence — NewsAPI + MediaStack (Tier 4)
# ---------------------------------------------------------------------------
# NewsAPI (free dev: 100 req/day) — 150k+ sources
# Get key: https://newsapi.org/register → free signup
# NEWS_API_KEY="..."

# MediaStack (free: 500 req/month) — live news in 50+ languages
# Get key: https://mediastack.com → free signup
# MEDIASTACK_API_KEY="..."

# ---------------------------------------------------------------------------
# Corporate intelligence — OpenCorporates (Tier 6)
# ---------------------------------------------------------------------------
# OpenCorporates (free: 500 req/day with key) — largest open company database
# Get key: https://opencorporates.com/api_accounts/new → free registration
# OPENCORPORATES_API_KEY="..."
